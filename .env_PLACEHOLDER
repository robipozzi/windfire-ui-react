# ---------------------------------------------------------------------------
# Keycloak connection — choose ONE of the two solutions below
# ---------------------------------------------------------------------------

# SOLUTION 1: HTTPS proxy (keep Keycloak on HTTP, proxy via Express/CRA server)
# The browser calls https://<host>/keycloak/*, the server forwards to Keycloak
# over HTTP — no mixed-content error.
# Requires KEYCLOAK_PROXY_TARGET to be set (not bundled into the React build).
REACT_APP_KEYCLOAK_URL=/keycloak
KEYCLOAK_PROXY_TARGET=<PUT_KEYCLOAK_HTTP_URL_HERE>

# SOLUTION 2: Keycloak served over HTTPS (full end-to-end TLS)
# Enable HTTPS on Keycloak (raspberry01), then uncomment the line below and
# comment out the Solution 1 lines above.
#REACT_APP_KEYCLOAK_URL=<PUT_KEYCLOAK_HTTPS_URL_HERE>

REACT_APP_KEYCLOAK_REALM=<PUT_KEYCLOAK_REALM_HERE>
REACT_APP_KEYCLOAK_CLIENT_ID=<PUT_KEYCLOAK_CLIENTID_HERE>
REACT_APP_RESTAURANTS_URL=<PUT_RESTAURANTS_API_ENDPOINT_HERE>
#REACT_APP_RESTAURANTS_URL=https://raspberry02:8081/restaurants

# ---------------------------------------------------------------------------
# SSL / HTTPS configuration
# ---------------------------------------------------------------------------

# Paths to TLS private key and certificate files used by the production HTTPS
# server (server.js / npm run serve).
# Defaults to ssl/key.pem and ssl/cert.pem if not set.
# Run ssl/generate-ssl.sh to create self-signed certificates for development.
SSL_KEY_FILE=ssl/key.pem
SSL_CRT_FILE=ssl/cert.pem

# Optional: override the default HTTPS port (default: 443)
# PORT=443

# Optional: override the default HTTP redirect port (default: 80)
# HTTP_PORT=80

# Optional: set to false to disable the HTTP->HTTPS redirect server
# (useful when a reverse proxy or load balancer handles redirects upstream)
# HTTP_REDIRECT=false

# ---------------------------------------------------------------------------
# Development HTTPS (CRA webpack-dev-server)
# Uncomment the lines below to enable HTTPS in `npm start` / run.sh --dev
# ---------------------------------------------------------------------------
# HTTPS=true
# SSL_KEY_FILE=ssl/key.pem
# SSL_CRT_FILE=ssl/cert.pem